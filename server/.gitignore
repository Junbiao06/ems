# ============================================
# Server 后端特定忽略规则
# ============================================

# Node.js 依赖
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 包管理器锁文件（根据实际使用的包管理器取消注释）
# package-lock.json  # 如果使用 npm
# yarn.lock         # 如果使用 yarn
# pnpm-lock.yaml    # 如果使用 pnpm

# 环境变量（后端特定）
.env.local
.env.development.local
.env.test.local
.env.production.local

# 数据库相关
*.db
*.sqlite
*.sqlite3

# 上传文件/临时文件
uploads/
temp/
tmp/

# 后端构建输出
dist/
build/
lib/

# TypeScript 编译输出
*.tsbuildinfo

# 测试相关
coverage/
.nyc_output/

# 日志文件（后端特定）
logs/
*.log

# 密钥文件
*.pem
*.key
*.crt

# Docker 相关
Dockerfile.local
docker-compose.override.yml

# 开发工具
.vscode/launch.json
.vscode/tasks.json